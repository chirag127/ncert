---
/*
 * Sidebar — CSS-only drawer shell (inlined, was @chirag127/astro-chrome).
 * Toggled by the `#sb-toggle` checkbox; the BottomBar "Menu" action and any
 * `<label for="sb-toggle">` open it. Slot holds per-app nav (AppSidebarContent).
 */
---
<input type="checkbox" id="sb-toggle" class="sb-toggle" hidden />
<label for="sb-toggle" class="sb-scrim" aria-hidden="true"></label>
<aside class="sidebar" aria-label="Section navigation">
  <div class="sb-inner">
    <slot />
  </div>
</aside>
<style>
  .sidebar {
    flex: none;
    width: 232px;
    border-right: 1px solid var(--rule);
    padding: 20px 16px;
    align-self: stretch;
  }
  .sb-inner { position: sticky; top: 76px; }
  .sb-scrim { display: none; }
  @media (max-width: 767px) {
    .sidebar {
      position: fixed;
      inset: 0 auto 0 0;
      z-index: 60;
      width: 264px;
      max-width: 82vw;
      background: var(--paper);
      transform: translateX(-100%);
      transition: transform 0.2s ease;
      overflow-y: auto;
    }
    .sb-toggle:checked ~ .sidebar { transform: translateX(0); }
    .sb-toggle:checked ~ .sb-scrim {
      display: block;
      position: fixed;
      inset: 0;
      z-index: 55;
      background: rgba(0, 0, 0, 0.5);
    }
    .sb-inner { top: 0; }
  }
</style>
