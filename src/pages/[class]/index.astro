---
/*
 * /[class]/index.astro — subject picker for a given class.
 *
 * Lists every (subject × language) tile available in books.json for the
 * selected class. Each tile links to /[class]/[subject]/[lang]/.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'
import { CLASSES, classLabel, langLabel, loadCatalog, subjectLabel } from '~/lib/catalog'

export function getStaticPaths() {
  return CLASSES.map((cls) => ({ params: { class: cls } }))
}

const { class: cls } = Astro.params
const entries = loadCatalog().filter((b) => b.class === cls)
const title = `${classLabel(cls as string)} — NCERT`
---

<BaseLayout title={title} description={`NCERT textbooks for ${classLabel(cls as string)}.`}>
  <div class="spine">
    <header class="page-head">
      <p class="eyebrow mono"><a href="/">NCERT</a> / {classLabel(cls as string).toUpperCase()}</p>
      <h1>{classLabel(cls as string)}.</h1>
      <p class="lede">Pick a subject. PDFs open from GitHub releases.</p>
    </header>

    {entries.length === 0 ? (
      <p class="empty">No books indexed yet for this class.</p>
    ) : (
      <ul class="tile-grid">
        {entries.map((b) => (
          <li class="tile">
            <a href={`/${b.class}/${b.subject}/${b.lang}/`}>
              <span class="tile-subject">{subjectLabel(b.subject)}</span>
              <span class="tile-meta mono">{langLabel(b.lang)}</span>
              <span class="tile-title">{b.title}</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>

<style>
  .page-head {
    padding-block: clamp(1.5rem, 4vw, 2.5rem) 1.25rem;
    border-bottom: 1px solid var(--rule);
  }
  .eyebrow {
    margin: 0 0 0.75rem;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }
  .eyebrow a { color: inherit; text-decoration: none; }
  .eyebrow a:hover { color: var(--cinnabar); }
  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.05;
  }
  .lede { margin: 0.75rem 0 0; color: var(--ink-mute); max-width: 60ch; }
  .tile-grid {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 16px;
  }
  .tile a {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem;
    background: var(--card, #1a1d24);
    border: 1px solid var(--rule);
    text-decoration: none;
    color: var(--ink);
    min-height: 100px;
  }
  .tile a:hover { border-color: var(--cinnabar); }
  .tile-subject { font-family: var(--font-display); font-size: 1.125rem; font-weight: 500; }
  .tile-meta { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--cinnabar); }
  .tile-title { font-size: 0.875rem; color: var(--ink-mute); }
  .empty { padding: 2rem 0; color: var(--ink-mute); }
</style>
