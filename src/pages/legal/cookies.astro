---
import BaseLayout from '~/layouts/BaseLayout.astro'

const updated = '2026-06-19'
---

<BaseLayout title="Cookie policy — Books" description="What cookies books.oriz.in uses.">
  <div class="spine-prose">
    <header class="page-head">
      <p class="eyebrow">
        <a href="/">CATALOGUE</a> / <a href="/legal/">LEGAL</a> / COOKIES
      </p>
      <h1>Cookie policy.</h1>
      <p class="meta">Last updated · {updated}</p>
    </header>

    <article class="prose">
      <p>
        This site uses the smallest set of cookies and storage we can get
        away with.
      </p>

      <h2>What we set</h2>
      <p>
        Nothing. This site has no accounts and sets no first-party cookies or
        persistent storage of its own.
      </p>

      <h2>Third parties</h2>
      <ul>
        <li>
          <strong>Cloudflare</strong> may set anti-abuse cookies (Turnstile,
          bot management). These are essential for site availability.
        </li>
      </ul>

      <h2>Opting out</h2>
      <p>
        You can clear localStorage and cookies for
        <code>ncert.oriz.in</code> from your browser's site-data settings.
      </p>
    </article>
  </div>
</BaseLayout>
