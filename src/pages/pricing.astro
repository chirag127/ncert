---
/*
 * /pricing — v0 stub. Free static-PDF directory, no paid tier.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'
---

<BaseLayout title="Pricing — NCERT" description="ncert.oriz.in is free for students.">
  <div class="spine-prose">
    <header class="page-head">
      <p class="eyebrow"><a href="/">CATALOGUE</a> / PRICING</p>
      <h1>Pricing.</h1>
    </header>
    <article class="prose">
      <p class="lede">
        ncert.oriz.in is <strong>free for students and parents</strong>. There
        is no paid tier, no subscription, and no upsell.
      </p>
      <p>
        Hosting runs on Cloudflare's free plan; PDFs are served from GitHub
        Releases. There is nothing to charge for. If you find this useful, the
        most helpful thing is to share the link with a parent or teacher.
      </p>
      <h2>Sponsoring the project</h2>
      <p>
        If you want to support the cost of merging more textbooks, see
        <a href="/contact/">contact</a>.
      </p>
    </article>
  </div>
</BaseLayout>
